{{ 'coiriva-faq.css' | asset_url | stylesheet_tag }}

<section class="coiriva-faq color-{{ section.settings.color_scheme }}" aria-labelledby="coiriva-faq-title-{{ section.id }}">
  <div class="coiriva-faq__inner page-width">
    <div class="coiriva-faq__header">
      {% if section.settings.eyebrow != blank %}
        <p class="coiriva-faq__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 id="coiriva-faq-title-{{ section.id }}" class="coiriva-faq__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="coiriva-faq__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>

    <div class="coiriva-faq__grid">
      <div class="coiriva-faq__visual" aria-hidden="true">
        <span class="coiriva-faq__badge">Garden Help</span>
        <div class="coiriva-faq__card">
          <span class="coiriva-faq__icon">🌱</span>
          <strong>{{ section.settings.visual_title | escape }}</strong>
          <small>{{ section.settings.visual_text | escape }}</small>
        </div>
      </div>

      <div class="coiriva-faq__items">
        {% for block in section.blocks %}
          <details class="coiriva-faq__item" {% if forloop.first and section.settings.open_first %}open{% endif %} {{ block.shopify_attributes }}>
            <summary class="coiriva-faq__question">
              <span>{{ block.settings.question | escape }}</span>
              <span class="coiriva-faq__plus" aria-hidden="true">+</span>
            </summary>
            <div class="coiriva-faq__answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Coiriva FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Questions gardeners ask" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Coco Coir Made Simple" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Quick answers that help new gardeners understand how Coiriva fits into their growing routine." },
    { "type": "checkbox", "id": "open_first", "label": "Open first question by default", "default": true },
    { "type": "text", "id": "visual_title", "label": "Visual title", "default": "Easy for beginners" },
    { "type": "text", "id": "visual_text", "label": "Visual text", "default": "Soak, expand, mix, and plant in minutes." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How do I use coconut coir bricks?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Place the brick in a container, add water, and let it expand. Once loose and fluffy, mix it into your potting blend or use it as a growing medium base.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coiriva FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How much does one brick expand?", "answer": "<p>Each compressed brick expands many times its size after hydration, creating a lightweight, airy growing medium for plants.</p>" } },
        { "type": "faq", "settings": { "question": "Is coco coir good for indoor and outdoor plants?", "answer": "<p>Yes. Coco coir works well for many indoor plants, container gardens, seed starting, raised beds, and garden mixes when used properly.</p>" } },
        { "type": "faq", "settings": { "question": "Does coco coir help with watering?", "answer": "<p>Coco coir helps hold moisture while still supporting airflow, which can make watering easier and support healthier root zones.</p>" } },
        { "type": "faq", "settings": { "question": "Can I mix it with soil?", "answer": "<p>Yes. Many gardeners mix coco coir with soil, compost, perlite, or other amendments to improve texture, moisture retention, and drainage.</p>" } }
      ]
    }
  ]
}
{% endschema %}
