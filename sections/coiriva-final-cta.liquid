{{ 'coiriva-final-cta.css' | asset_url | stylesheet_tag }}

<section class="coiriva-final-cta color-{{ section.settings.color_scheme }}" aria-labelledby="coiriva-final-cta-title-{{ section.id }}">
  <div class="coiriva-final-cta__inner page-width">
    <div class="coiriva-final-cta__content">
      {% if section.settings.eyebrow != blank %}
        <p class="coiriva-final-cta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 id="coiriva-final-cta-title-{{ section.id }}" class="coiriva-final-cta__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="coiriva-final-cta__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}

      <div class="coiriva-final-cta__actions">
        {% if section.settings.primary_label != blank %}
          <a class="coiriva-final-cta__button coiriva-final-cta__button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
            {{ section.settings.primary_label | escape }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank %}
          <a class="coiriva-final-cta__button coiriva-final-cta__button--secondary" href="{{ section.settings.secondary_link | default: '#MainContent' }}">
            {{ section.settings.secondary_label | escape }}
          </a>
        {% endif %}
      </div>

      <div class="coiriva-final-cta__trust" aria-label="Coiriva shopping benefits">
        <span>🚚 Fast US Shipping</span>
        <span>🌱 Expands 8–10×</span>
        <span>🛡️ 60-Day Guarantee</span>
      </div>
    </div>

    <div class="coiriva-final-cta__visual coiriva-final-cta__visual--photo">
      <img
        src="{{ 'cocogrows-lifestyle-cta.webp' | asset_url }}"
        alt="Healthy garden plants with expanded coco coir and coco coir brick"
        loading="lazy"
        decoding="async"
        width="514"
        height="416"
      >
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Coiriva final CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ready to grow better?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start With Better Coco Coir Today."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Turn compact coconut coir bricks into a clean, airy growing medium made for healthier roots, better moisture, and easier gardening."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Coco Coir"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "visual_title",
      "label": "Visual card title",
      "default": "Garden-ready in minutes"
    },
    {
      "type": "text",
      "id": "visual_text",
      "label": "Visual card text",
      "default": "Hydrate, expand, plant."
    }
  ],
  "presets": [
    {
      "name": "Coiriva final CTA"
    }
  ]
}
{% endschema %}
