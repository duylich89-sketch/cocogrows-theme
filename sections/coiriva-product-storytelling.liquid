{{ 'coiriva-product-storytelling.css' | asset_url | stylesheet_tag }}
<script src="{{ 'coiriva-product-storytelling.js' | asset_url }}" defer="defer"></script>

<section class="coiriva-storytelling" id="coiriva-product-storytelling">
  <div class="page-width">
    <div class="coiriva-storytelling__eyebrow">Premium Coco Coir System</div>
    <h2 class="coiriva-storytelling__title">Everything Your Plants Need To Grow Stronger</h2>
    <p class="coiriva-storytelling__subtitle">A cleaner, lighter growing medium designed for everyday gardeners, seedlings, containers, raised beds, and healthier root development.</p>

    <div class="coiriva-feature-grid" aria-label="Product benefits">
      <article class="coiriva-feature-card">
        <div class="coiriva-feature-card__icon">💧</div>
        <h3>Holds Moisture</h3>
        <p>Keeps roots hydrated longer between watering while helping reduce dry pockets.</p>
      </article>
      <article class="coiriva-feature-card">
        <div class="coiriva-feature-card__icon">🌱</div>
        <h3>Strong Root Growth</h3>
        <p>Creates a clean, airy structure that supports oxygen flow and healthy root development.</p>
      </article>
      <article class="coiriva-feature-card">
        <div class="coiriva-feature-card__icon">🥥</div>
        <h3>Natural Coconut Fiber</h3>
        <p>Made from coconut husks, a renewable material gardeners can feel good using.</p>
      </article>
      <article class="coiriva-feature-card">
        <div class="coiriva-feature-card__icon">🌬️</div>
        <h3>Better Drainage</h3>
        <p>Helps prevent compaction and supports better airflow for everyday growing.</p>
      </article>
    </div>

    <div class="coiriva-before-after">
      <div class="coiriva-before-after__content">
        <span class="coiriva-pill">Before / After</span>
        <h3>From Compact Brick To Garden-Ready Coir</h3>
        <p>Just add water and watch compact coco coir expand into a rich, airy medium for pots, seed starting, raised beds, herbs, vegetables, and more.</p>
        <div class="coiriva-mini-stats">
          <span>8–10× Expansion</span>
          <span>Ready in Minutes</span>
          <span>Easy To Store</span>
        </div>
      </div>
      <div class="coiriva-before-after__visual" data-coiriva-before-after>
        <div class="coiriva-ba-card coiriva-ba-card--before">
          <span>BEFORE</span>
          <strong>Compact Brick</strong>
          <p>Small, lightweight, and easy to store.</p>
        </div>
        <div class="coiriva-ba-arrow">→</div>
        <div class="coiriva-ba-card coiriva-ba-card--after">
          <span>AFTER</span>
          <strong>Rich Coco Coir</strong>
          <p>Clean, fluffy, and ready for planting.</p>
        </div>
      </div>
    </div>

    <div class="coiriva-switch-section">
      <div class="coiriva-section-heading">
        <span class="coiriva-pill">Why Gardeners Switch</span>
        <h3>Cleaner Than Soil. Easier Than Heavy Bags.</h3>
      </div>
      <div class="coiriva-switch-grid">
        <div>✓ Expands fast with water</div>
        <div>✓ Stores compactly anywhere</div>
        <div>✓ Light, airy texture</div>
        <div>✓ Great for containers</div>
        <div>✓ Mixes with potting soil</div>
        <div>✓ Supports strong roots</div>
      </div>
    </div>

    <div class="coiriva-comparison">
      <div class="coiriva-section-heading">
        <span class="coiriva-pill">Comparison</span>
        <h3>Why Cocogrows Beats Ordinary Growing Mediums</h3>
      </div>
      <div class="coiriva-comparison__table" role="table" aria-label="Cocogrows comparison table">
        <div class="coiriva-comparison__row coiriva-comparison__row--head" role="row">
          <div role="columnheader">Feature</div><div role="columnheader">Cocogrows</div><div role="columnheader">Peat Moss</div><div role="columnheader">Garden Soil</div>
        </div>
        <div class="coiriva-comparison__row" role="row">
          <div role="cell">Moisture retention</div><div role="cell">Excellent</div><div role="cell">Good</div><div role="cell">Varies</div>
        </div>
        <div class="coiriva-comparison__row" role="row">
          <div role="cell">Airflow for roots</div><div role="cell">Excellent</div><div role="cell">Medium</div><div role="cell">Can compact</div>
        </div>
        <div class="coiriva-comparison__row" role="row">
          <div role="cell">Storage</div><div role="cell">Compact brick</div><div role="cell">Bulky bag</div><div role="cell">Heavy bag</div>
        </div>
        <div class="coiriva-comparison__row" role="row">
          <div role="cell">Ease of use</div><div role="cell">Just add water</div><div role="cell">Mix required</div><div role="cell">Heavy handling</div>
        </div>
      </div>
    </div>

    <div class="coiriva-lifestyle">
      <div class="coiriva-section-heading">
        <span class="coiriva-pill">Garden Uses</span>
        <h3>Made For Everyday Planting Projects</h3>
      </div>
      <div class="coiriva-lifestyle__grid">
        <article><span>🪴</span><strong>Indoor Plants</strong><p>Light, airy support for potted plants.</p></article>
        <article><span>🥬</span><strong>Vegetables</strong><p>Great for raised beds and garden mixes.</p></article>
        <article><span>🌿</span><strong>Seed Starting</strong><p>Clean texture for delicate young roots.</p></article>
        <article><span>🌸</span><strong>Flowers & Herbs</strong><p>Moisture-friendly medium for daily growing.</p></article>
      </div>
    </div>

    <div class="coiriva-reviews-pro">
      <div class="coiriva-section-heading">
        <span class="coiriva-pill">Loved By Gardeners</span>
        <h3>Real Reasons Gardeners Come Back</h3>
      </div>
      <div class="coiriva-reviews-pro__grid">
        <article><div class="coiriva-stars">★★★★★</div><p>“The brick expanded quickly and made a clean, fluffy mix for my seedlings.”</p><strong>Sarah M. · Austin, TX</strong><span>Verified gardener ✓</span></article>
        <article><div class="coiriva-stars">★★★★★</div><p>“Easy to store and easy to use. I just add water when I need fresh coir.”</p><strong>David R. · Phoenix, AZ</strong><span>Verified gardener ✓</span></article>
        <article><div class="coiriva-stars">★★★★★</div><p>“Perfect for container gardening. The texture feels light and airy.”</p><strong>Karen L. · Tampa, FL</strong><span>Verified gardener ✓</span></article>
      </div>
    </div>

    <div class="coiriva-faq-pro">
      <div class="coiriva-section-heading">
        <span class="coiriva-pill">FAQ</span>
        <h3>Questions Gardeners Ask Before Buying</h3>
      </div>
      <div class="coiriva-faq-pro__items" data-coiriva-faq>
        <details open>
          <summary>How much does one coco coir brick expand?</summary>
          <p>Each compact brick expands about 8–10× when hydrated with water, turning into a light, airy growing medium.</p>
        </details>
        <details>
          <summary>Can I use it by itself?</summary>
          <p>You can use hydrated coco coir by itself for many planting projects, or mix it with potting soil, compost, perlite, or other amendments depending on your plants.</p>
        </details>
        <details>
          <summary>Is it good for seedlings and containers?</summary>
          <p>Yes. Coco coir is especially useful for seedlings, pots, containers, raised beds, herbs, vegetables, and everyday gardening projects.</p>
        </details>
        <details>
          <summary>How long does delivery take?</summary>
          <p>Orders ship from the USA and typically arrive in 2–5 business days after processing.</p>
        </details>
      </div>
    </div>

    <div class="coiriva-story-cta">
      <div>
        <span class="coiriva-pill">Ready To Grow Better?</span>
        <h3>Start With Premium Coco Coir Today.</h3>
        <p>Cleaner mixes, stronger roots, easier storage, and a better gardening experience.</p>
      </div>
      <a href="#MainProduct-{{ section.id }}" class="coiriva-story-cta__button" data-coiriva-scroll-buybox>Shop Coco Coir</a>
    </div>
  </div>
</section>

