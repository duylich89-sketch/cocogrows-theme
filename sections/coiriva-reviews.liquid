{{ 'coiriva-reviews.css' | asset_url | stylesheet_tag }}

<section class="coiriva-reviews color-{{ section.settings.color_scheme }}" aria-labelledby="coiriva-reviews-title-{{ section.id }}">
  <div class="coiriva-reviews__inner page-width">
    <div class="coiriva-reviews__header">
      {% if section.settings.eyebrow != blank %}
        <p class="coiriva-reviews__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 id="coiriva-reviews-title-{{ section.id }}" class="coiriva-reviews__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="coiriva-reviews__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>

    <div class="coiriva-reviews__summary" aria-label="Customer review summary">
      <div class="coiriva-reviews__score">
        <span class="coiriva-reviews__stars" aria-hidden="true">★★★★★</span>
        <strong>{{ section.settings.rating_text | escape }}</strong>
      </div>
      <span class="coiriva-reviews__divider" aria-hidden="true"></span>
      <p>{{ section.settings.trust_text | escape }}</p>
    </div>

    <div class="coiriva-reviews__grid">
      {% for block in section.blocks %}
        <article class="coiriva-review-card" {{ block.shopify_attributes }}>
          <div class="coiriva-review-card__top">
            <div class="coiriva-review-card__avatar" aria-hidden="true">{{ block.settings.initials | escape }}</div>
            <div>
              <div class="coiriva-review-card__stars" aria-hidden="true">★★★★★</div>
              <h3 class="coiriva-review-card__name">{{ block.settings.name | escape }}</h3>
              {% if block.settings.location != blank %}
                <p class="coiriva-review-card__location">{{ block.settings.location | escape }}</p>
              {% endif %}
            </div>
          </div>

          {% if block.settings.title != blank %}
            <p class="coiriva-review-card__title">“{{ block.settings.title | escape }}”</p>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="coiriva-review-card__text">{{ block.settings.text | escape }}</p>
          {% endif %}

          <div class="coiriva-review-card__footer">
            <span>Verified gardener</span>
            <span class="coiriva-review-card__check" aria-hidden="true">✓</span>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Coiriva reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Loved by home gardeners"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gardeners Are Growing Better With Cocogrows"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Realistic feedback-style cards for a premium homepage experience. Replace with verified reviews once your review app is connected."
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "4.9/5 average rating"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust text",
      "default": "Trusted by gardeners across the USA"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review card",
      "settings": [
        {
          "type": "text",
          "id": "initials",
          "label": "Avatar initials",
          "default": "SM"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Austin, TX"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "My seedlings finally stayed hydrated."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "The coir expanded quickly and gave my plants a clean, fluffy growing mix. It holds moisture without feeling heavy."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coiriva reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review", "settings": { "initials": "DR", "name": "David R.", "location": "Phoenix, AZ", "title": "Easy to store, easy to use.", "text": "I like that the bricks are compact until I need them. Add water, wait a few minutes, and I have plenty of growing medium." } },
        { "type": "review", "settings": { "initials": "KL", "name": "Karen L.", "location": "Tampa, FL", "title": "Great for container gardening.", "text": "The texture is light and airy, and my patio plants seem happier. It mixes well with my usual potting soil." } }
      ]
    }
  ]
}
{% endschema %}
