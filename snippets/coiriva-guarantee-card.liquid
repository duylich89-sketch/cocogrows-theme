{% if settings.enable_guarantee_card != false %}
  <article class="coiriva-trust-card" aria-label="60 day guarantee">
    <div class="coiriva-trust-card__head"><span class="coiriva-trust-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4c-8 1-14 5-15 14 8 1 13-2 15-14Z"></path><path d="M4 20c4-6 8-9 14-13"></path></svg></span><span>{{ settings.trust_guarantee_title | default: 'Grow With Confidence' }}</span></div>
    <div class="coiriva-trust-card__body">
      <div><strong>{{ settings.trust_guarantee_heading | default: '60-Day Money-Back Guarantee' }}</strong></div>
      <div>{{ settings.trust_guarantee_text | default: "Love it or we'll make it right." }}</div>
    </div>
  </article>
{% endif %}
