{%- liquid
  assign rating_value = block.settings.rating | default: 4.9
  assign rating_link = block.settings.scroll_id | default: '#reviews'
  assign review_label = block.settings.label | strip
  if review_label == blank or review_label contains 'xxxx'
    assign review_label = 'Rated by 3,200+ Home Gardeners'
  endif
-%}

<div class="rating-stars coiriva-premium-rating" style="--rating:{{ rating_value }};--star-color:{{ block.settings.star_color }};--font-size:{{ block.settings.size | divided_by: 10.0 }}rem;--alignment:{{ block.settings.alignment }};{% if margins %}--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;{% endif %}" {% if block_attributes %}{{ block.shopify_attributes }}{% endif %}>
  <a class="coiriva-premium-rating__link" href="{{ rating_link }}" aria-label="View customer reviews">
    <div class="coiriva-premium-rating__topline">
      <span class="coiriva-premium-rating__stars" aria-hidden="true">★★★★★</span>
      <strong class="coiriva-premium-rating__score">{{ rating_value }}/5</strong>
    </div>
    <div class="coiriva-premium-rating__copy">
      <span class="coiriva-premium-rating__main">{{ review_label }}</span>
      <span class="coiriva-premium-rating__sub">✓ Verified Reviews · Trusted by US Gardeners</span>
    </div>
  </a>
</div>
