    "coiriva-faq-final-a-task6": {
      "type": "coiriva-faq",
      "settings": {
        "eyebrow": "Questions gardeners ask",
        "heading": "Coco Coir Made Simple",
        "subheading": "Quick answers that help new gardeners understand how Coiriva fits into their growing routine.",
