        "visual_title": "Easy for beginners",
        "visual_text": "Soak, expand, mix, and plant in minutes."
      },
      "blocks": {
        "faq1": {
          "type": "faq",
          "settings": {
            "question": "How much does one brick expand?",
            "answer": "<p>Each compressed brick expands many times its size after hydration, creating a lightweight, airy growing medium for plants.</p>"
          }
        },
        "faq2": {
          "type": "faq",
          "settings": {
            "question": "Is coco coir good for indoor and outdoor plants?",
            "answer": "<p>Yes. Coco coir works well for many indoor plants, container gardens, seed starting, raised beds, and garden mixes when used properly.</p>"
          }
        },
        "faq3": {
          "type": "faq",
          "settings": {
            "question": "Does coco coir help with watering?",
            "answer": "<p>Coco coir helps hold moisture while still supporting airflow, which can make watering easier and support healthier root zones.</p>"
          }
        },
        "faq4": {
          "type": "faq",
          "settings": {
            "question": "Can I mix it with soil?",
            "answer": "<p>Yes. Many gardeners mix coco coir with soil, compost, perlite, or other amendments to improve texture, moisture retention, and drainage.</p>"
          }
        }
      },
      "block_order": [
